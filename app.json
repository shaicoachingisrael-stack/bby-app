{
  "expo": {
    "name": "Body by you",
    "slug": "bby-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bbyapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bodybyyou.app",
      "usesAppleSignIn": true,
      "entitlements": {
        "aps-environment": "development"
      }
    },
    "android": {
      "package": "com.bodybyyou.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-fix-ios-spaces",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8",
          "dark": {
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A0A0A",
          "defaultChannel": "default"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "BBY a besoin d'accéder à tes photos pour ta photo de profil.",
          "cameraPermission": "BBY a besoin d'accéder à ta caméra pour prendre ta photo de profil."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1016358247257-bir0vffvlos6a2trmn9g65tpfo3cg9hk"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
